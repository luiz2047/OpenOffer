# OpenOffer local environment
#
# Copy to `.env` and fill in local secrets. `.env` is git-ignored.

# Required only for intentional live Yandex prompt eval network calls.
# Leave commented for dry-run/local development.
# YANDEX_EVAL_LIVE=1
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Optional aliases also supported by scripts/yandex-prompt-eval.cjs:
# YANDEXGPT_API_KEY=
# YANDEXGPT_FOLDER_ID=

# Optional local runtime answer-style override.
# Valid values: standard, strict, expanded, hint, grounded
# OPENOFFER_ANSWER_STYLE=strict

# Legacy/debug-only Yandex adapter prompt override. Prefer the UI Answer style
# setting for normal app use.
# OPENOFFER_YANDEX_PROMPT_PACK=yandex-ru-lite
